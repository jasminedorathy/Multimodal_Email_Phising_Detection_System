{
  "manifest_version": 3,
  "name": "PhishGuard Inspector",
  "version": "1.0",
  "description": "Quickly inspect active tabs or copied text for phishing vectors.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Analyze Threat"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
